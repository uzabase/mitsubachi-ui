{
  "name": "mitsubachi-ui",
  "version": "2.1.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./mock": "./dist/mock.js",
    "./custom-elements.json": "./dist/custom-elements.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "run-s build:vite build:manifest build:mock",
    "build:vite": "vite build",
    "build:manifest": "custom-elements-manifest analyze --config custom-elements-manifest.config.mjs",
    "build:mock": "tsx tools/generate-mock.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "run-s \"format:* !format:prettier:check\"",
    "format:prettier": "prettier --write '(.storybook|src|stories|tests|tools)/**/*.ts'",
    "format:prettier:check": "prettier --check '(.storybook|src|stories|tests|tools)/**/*.ts'",
    "format:lint": "stylelint --fix 'src/**/*.css'",
    "test": "vitest",
    "fetch-icons": "tsx tools/fetch-icons.ts",
    "fetch-icon-colors": "tsx tools/fetch-icon-colors.ts",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uzabase/mitsubachi-ui.git"
  },
  "files": [
    "dist"
  ],
  "license": "ISC",
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@sp-design/recet.css": "git+https://github.com/uzabase/sp-design-reset.css#semver:^1.0.2"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/web-components-vite": "^10.3.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.1",
    "dedent": "^1.7.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-wc": "^3.1.0",
    "globals": "^17.4.0",
    "lit": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.2",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "shadow-dom-testing-library": "^1.13.1",
    "storybook": "^10.3.3",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.1",
    "yakuhanjp": "^4.1.1"
  },
  "customElements": "dist/custom-elements.json"
}
